# Valid harbor.yml with HTTP + HTTPS enabled.
# Copy to harbor-install/harbor/harbor.yml (or merge https block carefully).
# Certificate files must exist at the paths below BEFORE ./prepare
#
# Common YAML mistakes that cause:
#   ParserError: expected <block end>, but found '<block mapping start>'
# - Uncommenting only some lines under https (leaves orphan keys)
# - Duplicate http: or https: at root
# - Wrong indentation (use spaces only, 2 spaces per level)
# - Tab characters mixed with spaces

hostname: 145.38.204.113

# Keep http if you want both 80 and 443; or comment entire http block for HTTPS-only per Harbor docs
http:
  port: 80

# All three keys must be uncommented together; indent with TWO spaces under https:
https:
  port: 443
  certificate: /data/cert/server.crt
  private_key: /data/cert/server.key

harbor_admin_password: Harbor12345

database:
  password: root123
  max_idle_conns: 100
  max_open_conns: 900
  conn_max_lifetime: 5m
  conn_max_idle_time: 0

data_volume: /data

trivy:
  ignore_unfixed: false
  skip_update: false
  skip_java_db_update: false
  offline_scan: false
  security_check: vuln
  insecure: false
  timeout: 5m0s

jobservice:
  max_job_workers: 10
  max_job_duration_hours: 24
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1

notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: /var/log/harbor

_version: 2.14.0

upload_purging:
  enabled: true
  age: 168h
  interval: 24h
  dryrun: false

cache:
  enabled: false
  expire_hours: 24
